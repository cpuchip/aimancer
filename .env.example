# AIMANCER apprentice — any OpenAI-compatible chat endpoint. Copy to .env (or
# export in your shell / set in the deploy environment) and fill in. NEVER
# commit real values. Unset APPRENTICE_BASE_URL = practice mode: the seeded
# offline generator answers draft requests, the game stays fully playable.

# The /v1 root of the endpoint (llama-chip router, llama.cpp, vLLM, OpenAI…)
APPRENTICE_BASE_URL=http://127.0.0.1:8090/v1

# Model ids per draft tier (either may be omitted — the other stands in)
APPRENTICE_MODEL_CHEAP=Qwen3-4B-Instruct-2507
APPRENTICE_MODEL_SMART=Qwen3-4B-Instruct-2507

# Optional bearer for hosted endpoints
#APPRENTICE_API_KEY=

# Per-request cap in ms (default 20000). On timeout the room REFUNDS the
# request through a logged draftFailed command.
#APPRENTICE_TIMEOUT_MS=20000
